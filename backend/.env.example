PORT=5000

# Connection string to the PostgreSQL database VM
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Replace 'localhost' with the Database VM's IP address when deployed in production
DATABASE_URL=postgresql://shutter_user:shutter_secure_pass_2026@localhost:5432/shutterscore

# A secure key used for signing JSON Web Tokens (change in production)
JWT_SECRET=shutter_score_secret_jwt_key_2026
